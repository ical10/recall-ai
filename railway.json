{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "RAILPACK"
  },
  "deploy": {
    "startCommand": "sh -c 'uv run uvicorn app.main:app --app-dir apps/api --host 0.0.0.0 --port $PORT'",
    "preDeployCommand": ["sh -c 'cd apps/api && uv run alembic upgrade head'"],
    "healthcheckPath": "/healthz",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
