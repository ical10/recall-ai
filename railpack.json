{
  "$schema": "https://schema.railpack.com",
  "provider": "python",
  "packages": {
    "python": "3.11",
    "node": "22"
  },
  "steps": {
    "build_spa": {
      "inputs": [
        { "step": "install" }
      ],
      "commands": [
        "npx -y pnpm@9.0.0 install --frozen-lockfile",
        "npx -y pnpm@9.0.0 run build"
      ]
    }
  },
  "deploy": {
    "startCommand": "sh -c 'uv run uvicorn app.main:app --app-dir apps/api --host 0.0.0.0 --port $PORT'"
  }
}
