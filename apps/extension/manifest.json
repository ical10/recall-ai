{
  "manifest_version": 3,
  "name": "RecallAI",
  "version": "0.1.0",
  "description": "Voice-first vocabulary review",
  "permissions": ["identity", "offscreen", "sidePanel", "storage"],
  "host_permissions": ["http://localhost:8000/*", "https://recallai.up.railway.app/*"],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
