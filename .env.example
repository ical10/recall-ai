DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/recallai
REDIS_URL=redis://localhost:6379/0
LLM_API_KEY=sk-or-v1-...
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=z-ai/glm-4.5-air:free
# Provider swap examples (no code change — set all three together):
#   OpenRouter:  LLM_BASE_URL=https://openrouter.ai/api/v1     LLM_MODEL=deepseek/deepseek-v4-flash
#   OpenCode Go: LLM_BASE_URL=https://opencode.ai/zen/go/v1    LLM_MODEL=deepseek-v4-flash
#   DeepSeek:    LLM_BASE_URL=https://api.deepseek.com/v1      LLM_MODEL=deepseek-chat
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI is required — no code default. Prod sets the Railway domain.
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback
SECRET_KEY=change-me-in-production
# SESSION_HTTPS_ONLY: dev=false, prod=true (signed session cookie travels HTTPS-only)
SESSION_HTTPS_ONLY=false
